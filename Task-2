using System;

namespace Task2
{
    enum StoreType
    {
        Grocery,
        Hardware,
        Clothing,
        Footwear
    }

    class Store : IDisposable
    {
        public string Name { get; set; }
        public string Address { get; set; }
        public StoreType Type { get; set; }

        private bool disposed = false;

        public Store(string name, string address, StoreType type)
        {
            Name = name;
            Address = address;
            Type = type;
            Console.WriteLine($"Магазин \"{Name}\" створено");
        }

        public void PrintInfo()
        {
            if (disposed)
                throw new ObjectDisposedException(Name);

            Console.WriteLine($"Назва: {Name}, Адреса: {Address}, Тип: {Type}");
        }

        public void Dispose()
        {
            Dispose(true);
            GC.SuppressFinalize(this);
        }

        protected virtual void Dispose(bool disposing)
        {
            if (disposed)
                return;

            if (disposing)
            {
                // Звільнення керованих ресурсів
                Console.WriteLine($"Ресурси магазину \"{Name}\" звільнено (Dispose)");
            }

            disposed = true;
        }
    }

    class Program
    {
        static void Main(string[] args)
        {
            using (Store store1 = new Store("Продукти24", "вул. Соборна, 1", StoreType.Grocery))
            {
                store1.PrintInfo();
            }

            // Явний виклик Dispose
            Store store2 = new Store("Будівельник", "вул. Шевченка, 10", StoreType.Hardware);
            store2.PrintInfo();
            store2.Dispose();

            Console.WriteLine("Кінець програми");
            Console.ReadKey();
        }
    }
}
